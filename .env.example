# Copy to .env at repo root and fill in.
# Loaded by ansible/reconcile.yml on every run. .env is gitignored.

# --- AdGuard first-run wizard (required) ------------------------------------
# bcrypted into AdGuard's persistent volume; re-runs are idempotent.
ADGUARD_USER=admin
ADGUARD_PASSWORD=

# --- Grafana ---------------------------------------------------------------
# If unset, ansible generates a strong password on first run and prints it.
# GRAFANA_ADMIN_PASSWORD=

# Slack bot token for Grafana managed alert contact points (chat:write +
# chat:write.public, invited to #infra #dns #network).
GRAFANA_SLACK_BOT_TOKEN=

# --- MikroTik exporter (mktxp) ---------------------------------------------
MIKROTIK_USER=
MIKROTIK_PASSWORD=

# --- Home Assistant Prometheus scrape (two-pass) ---------------------------
# This token is the only secret that has to be created by hand — HA's
# Long-Lived Access Tokens cannot be minted via API.
#   1. Bring HA up:           ansible-playbook ansible/reconcile.yml -e stack=smart-home
#   2. Open https://home-assistant.int, complete onboarding (owner user).
#   3. Profile (bottom-left) → Security → Long-Lived Access Tokens → Create.
#   4. Paste the token here, then re-run reconcile to apply.
# Without this token, the prometheus `home-assistant` target stays in
# `down (401)` and HA panels in dashboards show "No data".
HOMEASSISTANT_PROMETHEUS_TOKEN=

# --- Slack — ansible orchestration notifications ---------------------------
# Bot token used by ansible roles/common/slack.yml. Separate from Grafana
# token so revoking one doesn't break the other.
ANSIBLE_SLACK_TOKEN=

# --- Colima overrides (optional) -------------------------------------------
# Override globals.yaml defaults without editing yaml. Empty = use globals.
# COLIMA_PROFILE=homelab
# COLIMA_CPU=10
# COLIMA_MEMORY=32
# COLIMA_DISK=250
# COLIMA_NETWORK_ADDRESS=true

# --- Host LAN IP override (optional) ---------------------------------------
# Override globals.yaml's hostIp:auto detection.
# HOST_IP_OVERRIDE=192.168.10.3

# --- Internal CA paths (optional) ------------------------------------------
# Override caddy.caCert / caddy.caYaml from globals.yaml.
# CERT is the standalone .crt (devices trust this). CERT_YAML is the full
# k8s Secret form with both tls.crt and tls.key, kept private.
# CERT=/path/to/homelab-ca.crt
# CERT_YAML=/path/to/homelab-ca-secret.yaml

# --- mDNS reflector VM-side IP (optional) ----------------------------------
# Only set if your Colima vmnet IP isn't the typical 192.168.64.2.
# MDNS_VM_VMNET_IP=192.168.64.2

# --- Timezone --------------------------------------------------------------
# Applied as TZ env var to every stack container.
TZ=Europe/Warsaw
