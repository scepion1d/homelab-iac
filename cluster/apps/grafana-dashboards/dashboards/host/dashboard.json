{
  "title": "Host",
  "uid": "host-overview",
  "tags": ["host-exporter", "infra"],
  "schemaVersion": 39,
  "timezone": "",
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(node_uname_info, node)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Nodes",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 0 },
      "targets": [
        { "expr": "count(node_uname_info)", "refId": "A", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "graphMode": "none", "colorMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Host CPU cores",
      "description": "k3d nodes share one Docker VM kernel — all nodes report the same host. Use max() not sum().",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 0 },
      "targets": [
        { "expr": "max(count by (node, cpu) (node_cpu_seconds_total{node=~\"$node\"}))", "refId": "A", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "graphMode": "none", "colorMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Host CPU usage",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 0 },
      "targets": [
        { "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\", node=~\"$node\"}[$__range]))", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.7 },
            { "color": "red", "value": 0.9 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "graphMode": "area", "colorMode": "value" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Host RAM",
      "description": "k3d nodes share one Docker VM kernel — all nodes report the same host. Use max() not sum().",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 0 },
      "targets": [
        { "expr": "max(node_memory_MemTotal_bytes{node=~\"$node\"})", "refId": "A", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "graphMode": "none", "colorMode": "value" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Host RAM used",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 0 },
      "targets": [
        { "expr": "1 - max(node_memory_MemAvailable_bytes{node=~\"$node\"}) / max(node_memory_MemTotal_bytes{node=~\"$node\"})", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.7 },
            { "color": "red", "value": 0.9 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "graphMode": "area", "colorMode": "value" }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "HDD",
      "description": "Allocated size of /dev/vdb1 (main WSL2 data disk).",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 0 },
      "targets": [
        { "expr": "max(node_filesystem_size_bytes{node=~\"$node\", device=\"/dev/vdb1\"})", "refId": "A", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "graphMode": "none", "colorMode": "value" }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "HDD used",
      "description": "Used % of /dev/vdb1 (main WSL2 data disk).",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "targets": [
        { "expr": "1 - min(node_filesystem_avail_bytes{node=~\"$node\", device=\"/dev/vdb1\"}) / max(node_filesystem_size_bytes{node=~\"$node\", device=\"/dev/vdb1\"})", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.75 },
            { "color": "red", "value": 0.9 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "graphMode": "area", "colorMode": "value" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Uptime  (min node)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 0 },
      "targets": [
        { "expr": "min(time() - node_boot_time_seconds{node=~\"$node\"})", "refId": "A", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "graphMode": "none", "colorMode": "value" }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "CPU usage  (host)",
      "description": "k3d nodes share the same kernel — single host-level series.",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\", node=~\"$node\"}[$__rate_interval]))",
          "legendFormat": "host",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory used  (host)",
      "description": "k3d nodes share the same kernel /proc — single host-level series.",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "max(node_memory_MemTotal_bytes{node=~\"$node\"}) - max(node_memory_MemAvailable_bytes{node=~\"$node\"})",
          "legendFormat": "host",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Load average  (host, load1)",
      "description": "k3d nodes share the same kernel — single host-level series.",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "max(node_load1{node=~\"$node\"})", "legendFormat": "host", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0, "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Disk I/O  (host, read up / write down)",
      "description": "k3d nodes share the same disk — single host-level series.",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "max(sum by (node) (rate(node_disk_read_bytes_total{node=~\"$node\"}[$__rate_interval])))",
          "legendFormat": "read",
          "refId": "A"
        },
        {
          "expr": "-max(sum by (node) (rate(node_disk_written_bytes_total{node=~\"$node\"}[$__rate_interval])))",
          "legendFormat": "write",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Network RX per node  (excl. veth/cni/lo)",
      "description": "Each k3d node is its own Docker container with its own netns — per-node netdev traffic is real (unlike CPU/mem which share the kernel).",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 19 },
      "targets": [
        {
          "expr": "sum by (node) (rate(node_network_receive_bytes_total{node=~\"$node\", device!~\"lo|veth.*|cni.*|flannel.*|cilium.*|docker.*\"}[$__rate_interval])) * 8",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Network TX per node  (excl. veth/cni/lo)",
      "description": "Each k3d node is its own Docker container with its own netns — per-node netdev traffic is real (unlike CPU/mem which share the kernel).",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 19 },
      "targets": [
        {
          "expr": "sum by (node) (rate(node_network_transmit_bytes_total{node=~\"$node\", device!~\"lo|veth.*|cni.*|flannel.*|cilium.*|docker.*\"}[$__rate_interval])) * 8",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps", "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5, "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 20,
      "type": "table",
      "title": "Filesystem usage  (deduped by device)",
      "description": "k3d bind-mounts the same underlying disk into many container mountpoints. Aggregating by device shows one row per real filesystem.",
      "datasource": "Prometheus",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "targets": [
        {
          "expr": "max by (device, fstype) (1 - node_filesystem_avail_bytes{node=~\"$node\", fstype!~\"tmpfs|overlay|squashfs|nsfs|fuse.*\"} / node_filesystem_size_bytes{node=~\"$node\", fstype!~\"tmpfs|overlay|squashfs|nsfs|fuse.*\"})",
          "refId": "USED_PCT",
          "format": "table",
          "instant": true
        },
        {
          "expr": "max by (device, fstype) (node_filesystem_size_bytes{node=~\"$node\", fstype!~\"tmpfs|overlay|squashfs|nsfs|fuse.*\"})",
          "refId": "SIZE",
          "format": "table",
          "instant": true
        },
        {
          "expr": "min by (device, fstype) (node_filesystem_avail_bytes{node=~\"$node\", fstype!~\"tmpfs|overlay|squashfs|nsfs|fuse.*\"})",
          "refId": "AVAIL",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "device", "mode": "outer" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true, "Time 3": true,
              "fstype 2": true, "fstype 3": true
            },
            "renameByName": {
              "fstype 1": "fstype",
              "Value #USED_PCT": "used %",
              "Value #SIZE": "size",
              "Value #AVAIL": "available"
            },
            "indexByName": {
              "device": 0,
              "fstype": 1,
              "used %": 2,
              "available": 3,
              "size": 4
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "used %" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
              { "id": "min", "value": 0 }, { "id": "max", "value": 1 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 0.75 },
                { "color": "red", "value": 0.9 }
              ]}}
            ]
          },
          { "matcher": { "id": "byName", "options": "size" },
            "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "available" },
            "properties": [{ "id": "unit", "value": "bytes" }] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "used %", "desc": true }] }
    }
  ]
}
