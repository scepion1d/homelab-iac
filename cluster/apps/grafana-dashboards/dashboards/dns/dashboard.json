{
  "title": "Unbound DNS Resolver",
  "uid": "unbound-resolver",
  "tags": ["dns", "unbound", "recursive"],
  "schemaVersion": 39,
  "timezone": "",
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Uptime",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(unbound_time_up_seconds_total)", "refId": "A", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 300 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Cache Entries",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{
        "expr": "sum(unbound_rrset_cache_count) + sum(unbound_msg_cache_count)",
        "refId": "A", "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Recursion Time",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{
        "expr": "1000 * sum(unbound_recursion_time_seconds_avg)",
        "refId": "A", "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 200 },
            { "color": "red", "value": 500 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Recursive Replies",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{
        "expr": "sum(unbound_recursive_replies_total)",
        "refId": "A", "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Unwanted",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [{
        "expr": "sum(unbound_unwanted_queries_total) + sum(unbound_unwanted_replies_total)",
        "refId": "A", "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Exporter Up",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [{ "expr": "unbound_up", "refId": "A", "instant": true }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Queries",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "sum(rate(unbound_queries_total[$__rate_interval]))", "legendFormat": "queries/s", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 25, "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "hidden" } }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Outbound Queries",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "sum(rate(unbound_query_udpout_total[$__rate_interval]))", "legendFormat": "UDP out", "refId": "A" },
        { "expr": "sum(rate(unbound_query_tcpout_total[$__rate_interval]))", "legendFormat": "TCP out", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "UDP out" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "TCP out" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Latency",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [
        { "expr": "1000 * histogram_quantile(0.95, sum by (le) (rate(unbound_response_time_seconds_bucket[$__rate_interval])))", "legendFormat": "p95 (ms)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0, "showPoints": "never", "spanNulls": true }
        }
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "hidden" } }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Upstream Latency Buckets (% of queries)",
      "description": "Distribution of response times across histogram buckets. Each band shows the percentage of queries falling into that latency range.",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [
        { "expr": "100 * sum(rate(unbound_response_time_seconds_bucket{le=\"0.008192\"}[$__rate_interval])) / sum(rate(unbound_response_time_seconds_bucket{le=\"+Inf\"}[$__rate_interval]))", "legendFormat": "\u2264 8 ms", "refId": "A" },
        { "expr": "100 * (sum(rate(unbound_response_time_seconds_bucket{le=\"0.065536\"}[$__rate_interval])) - sum(rate(unbound_response_time_seconds_bucket{le=\"0.008192\"}[$__rate_interval]))) / sum(rate(unbound_response_time_seconds_bucket{le=\"+Inf\"}[$__rate_interval]))", "legendFormat": "8-64 ms", "refId": "B" },
        { "expr": "100 * (sum(rate(unbound_response_time_seconds_bucket{le=\"0.262144\"}[$__rate_interval])) - sum(rate(unbound_response_time_seconds_bucket{le=\"0.065536\"}[$__rate_interval]))) / sum(rate(unbound_response_time_seconds_bucket{le=\"+Inf\"}[$__rate_interval]))", "legendFormat": "64-256 ms", "refId": "C" },
        { "expr": "100 * (sum(rate(unbound_response_time_seconds_bucket{le=\"0.524288\"}[$__rate_interval])) - sum(rate(unbound_response_time_seconds_bucket{le=\"0.262144\"}[$__rate_interval]))) / sum(rate(unbound_response_time_seconds_bucket{le=\"+Inf\"}[$__rate_interval]))", "legendFormat": "256-512 ms", "refId": "D" },
        { "expr": "100 * (sum(rate(unbound_response_time_seconds_bucket{le=\"+Inf\"}[$__rate_interval])) - sum(rate(unbound_response_time_seconds_bucket{le=\"0.524288\"}[$__rate_interval]))) / sum(rate(unbound_response_time_seconds_bucket{le=\"+Inf\"}[$__rate_interval]))", "legendFormat": "> 512 ms", "refId": "E" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "custom": { "drawStyle": "line", "lineWidth": 0, "fillOpacity": 80, "showPoints": "never", "spanNulls": true, "stacking": { "mode": "normal", "group": "buckets" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "\u2264 8 ms" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "8-64 ms" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "64-256 ms" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "256-512 ms" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "> 512 ms" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean"] } }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Cache Entries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "targets": [
        { "expr": "sum(unbound_rrset_cache_count)", "legendFormat": "RRset", "refId": "A" },
        { "expr": "-1 * sum(unbound_msg_cache_count)", "legendFormat": "Message", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "RRset" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Message" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Cache Hit / Miss Rate",
      "description": "Derived from total answered queries minus recursive replies (= cache hits). Recursive replies = cache misses.",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "targets": [
        { "expr": "sum(rate(unbound_answer_rcodes_total[$__rate_interval])) - sum(rate(unbound_recursive_replies_total[$__rate_interval]))", "legendFormat": "Hits", "refId": "A" },
        { "expr": "-1 * sum(rate(unbound_recursive_replies_total[$__rate_interval]))", "legendFormat": "Misses", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Hits" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Misses" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Answer Types",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "targets": [
        { "expr": "sum(rate(unbound_answer_rcodes_total{rcode=\"NOERROR\"}[$__rate_interval]))", "legendFormat": "Success", "refId": "A" },
        { "expr": "sum(rate(unbound_answer_rcodes_total{rcode=\"NXDOMAIN\"}[$__rate_interval]))", "legendFormat": "NXDOMAIN", "refId": "B" },
        { "expr": "sum(rate(unbound_answer_rcodes_total{rcode=\"SERVFAIL\"}[$__rate_interval]))", "legendFormat": "SERVFAIL", "refId": "C" },
        { "expr": "sum(rate(unbound_answer_rcodes_total{rcode=~\"nodata\"}[$__rate_interval]))", "legendFormat": "NODATA", "refId": "D" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "lineWidth": 0, "fillOpacity": 80, "showPoints": "never", "spanNulls": true, "stacking": { "mode": "normal", "group": "answers" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "NXDOMAIN" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "SERVFAIL" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "NODATA" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Request Queue",
      "description": "Pending = queries in-flight waiting for recursive resolution. Evicted = old queries displaced by newer ones. Dropped = queries rejected (queue full).",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "targets": [
        { "expr": "sum(unbound_request_list_current_all)", "legendFormat": "Pending (all)", "refId": "A" },
        { "expr": "sum(unbound_request_list_current_user)", "legendFormat": "Pending (clients)", "refId": "B" },
        { "expr": "sum(rate(unbound_request_list_overwritten_total[$__rate_interval]))", "legendFormat": "Evicted/s", "refId": "C" },
        { "expr": "sum(rate(unbound_request_list_exceeded_total[$__rate_interval]))", "legendFormat": "Dropped/s", "refId": "D" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Pending (all)" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }, { "id": "custom.fillOpacity", "value": 15 }] },
          { "matcher": { "id": "byName", "options": "Pending (clients)" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Evicted/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }] },
          { "matcher": { "id": "byName", "options": "Dropped/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ]
}
