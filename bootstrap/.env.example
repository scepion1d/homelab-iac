# bootstrap/.env -- gitignored. Copy to bootstrap/.env and fill in.
# All bootstrap/*.sh scripts source this via lib.sh::load_env, so anything
# you set here is visible to every step.

# --- AdGuard first-run wizard (required for 07-adguard-setup.sh) ------------
# Pick something strong. AdGuard bcrypts and stores this in its PVC; if you
# lose the PVC, re-run 07 with the same (or new) values.
ADGUARD_USER=admin
ADGUARD_PASSWORD=

# --- Colima tunables (optional; override defaults in 01-start-runtime.sh) ---
# COLIMA_PROFILE=default
# COLIMA_CPU=6
# COLIMA_MEMORY=24
# COLIMA_DISK=100
# COLIMA_NETWORK_ADDRESS=true
