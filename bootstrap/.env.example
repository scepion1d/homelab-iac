# bootstrap/.env -- gitignored. Copy to bootstrap/.env and fill in.
# All bootstrap/*.sh scripts source this via lib.sh::load_env, so anything
# you set here is visible to every step.

# --- AdGuard first-run wizard (required for 07-adguard-setup.sh) ------------
# Pick something strong. AdGuard bcrypts and stores this in its PVC; if you
# lose the PVC, re-run 07 with the same (or new) values.
ADGUARD_USER=admin
ADGUARD_PASSWORD=

# --- Argo CD git repo credentials (required if cluster/globals.yaml repoUrl
# points at a private repo). Bootstrap step 04 calls `argocd repo add` so
# the root ApplicationSet can list cluster/apps/*. Without these set, the
# AppSet lands Degraded with "authentication required: Repository not
# found" until creds are added by hand.
#
# Token scope (fine-grained PAT, repo-only):
#   Settings -> Developer settings -> Personal access tokens (fine-grained)
#   Repository access: this repo only
#   Repository permissions: Contents = Read-only
ARGOCD_GIT_USER=
ARGOCD_GIT_PAT=

# --- Grafana Slack alerting (required if grafana-alerts app is enabled) -----
# Slack bot token (xoxb-...) for Grafana managed alert contact points.
# Create a Slack app with `chat:write` + `chat:write.public`, invite the bot
# to #infra, #cluster, #network, #dns. Without this Grafana CrashLoops
# because cluster/apps/grafana/_appset.yaml mounts it via envValueFrom.
# Bootstrap creates Secret monitoring/grafana-slack (key `token`).
GRAFANA_SLACK_BOT_TOKEN=

# --- Home Assistant scraping (optional; only if host/apps/home-assistant
# is deployed and you want HA metrics in Grafana). Two-pass setup:
#   1. Run ./bootstrap/09-host-apps.sh home-assistant to bring HA up.
#   2. Open http://<host LAN IP>:8123, create owner account.
#   3. Profile -> Security -> Long-Lived Access Tokens -> Create Token.
#   4. Paste here, then re-run ./bootstrap/06-cluster-secrets.sh.
# Bootstrap creates Secret monitoring/home-assistant-prometheus-token.
HOMEASSISTANT_PROMETHEUS_TOKEN=

# --- Host apps layer (optional; only needed once host/apps/* exists) --------
# Override LAN IP if auto-detection in host/globals.yaml picks the wrong NIC.
# Default `auto` uses the outbound interface for 8.8.8.8.
# HOST_IP_OVERRIDE=

# Timezone applied to every host app container's TZ env var.
# TZ=Europe/Warsaw

# --- Colima tunables (optional; override defaults in 01-start-runtime.sh) ---
# COLIMA_PROFILE=default
# COLIMA_CPU=6
# COLIMA_MEMORY=24
# COLIMA_DISK=100
# COLIMA_NETWORK_ADDRESS=true

# --- mDNS reflector overrides (only if your Colima VM uses non-default IPs) ---
# The in-VM reflector (host/apps/mdns-reflector) defaults to the typical
# Colima layout. If `colima ssh -- ip -br addr` shows different addresses,
# set these. The Mac-side reflector (bootstrap/11-mdns-reflector.sh)
# auto-discovers its own IPs and ignores these vars.
# MDNS_VM_USERMODE_IP=192.168.5.1
# MDNS_VM_VMNET_IP=192.168.64.3
