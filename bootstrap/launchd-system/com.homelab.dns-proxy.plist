<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Managed by bootstrap/06-dns-proxy.sh. The script copies this file to
  /Library/LaunchDaemons/com.homelab.dns-proxy.plist with DNS_UPSTREAM
  replaced by the live Colima VM IP. Edit the script (or this template)
  and re-run 06-dns-proxy.sh; do not hand-edit the installed copy.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.homelab.dns-proxy</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/usr/local/lib/homelab/dns-proxy.py</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>DNS_LISTEN</key>
    <string>__LAN_IP__</string>
    <key>DNS_UPSTREAM</key>
    <string>__VM_IP__</string>
    <key>DNS_PORT</key>
    <string>53</string>
  </dict>

  <!-- Run as root so we can bind UDP/53. -->
  <key>UserName</key>
  <string>root</string>

  <key>RunAtLoad</key>
  <true/>

  <!-- If python crashes or the VM IP becomes invalid, retry. -->
  <key>KeepAlive</key>
  <true/>

  <key>ThrottleInterval</key>
  <integer>5</integer>

  <key>StandardOutPath</key>
  <string>/var/log/homelab-dns-proxy.log</string>
  <key>StandardErrorPath</key>
  <string>/var/log/homelab-dns-proxy.log</string>
</dict>
</plist>
