<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.homelab.ansible-reconcile — safety-net reconcile.

  Templated by ansible (roles/host/tasks/services.yml) from
  globals.yaml > reconcile.reconcileIntervalSeconds (currently
  {{ reconcile_interval_seconds }}s).

  Drives /usr/local/lib/homelab/homelab-reconcile.sh, which acquires
  a shared flock so this never races com.homelab.git-pull's
  reconcile trigger.

  After this file changes, plist contents are NOT auto-reloaded
  (bootout/bootstrap from inside the running reconcile would kill
  the in-flight playbook). Apply manually:
    sudo launchctl bootout system/com.homelab.ansible-reconcile
    sudo launchctl bootstrap system /Library/LaunchDaemons/com.homelab.ansible-reconcile.plist
  Or reboot — launchd reloads plists on boot.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.homelab.ansible-reconcile</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/lib/homelab/homelab-reconcile.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/homelab-admin/src/homelab-iac</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>/Users/homelab-admin</string>
    <key>ANSIBLE_CONFIG</key>
    <string>/Users/homelab-admin/src/homelab-iac/ansible.cfg</string>
    <!-- slack_summary callback uses this to suppress noisy "all-OK,
         no-change" pings on scheduled (launchd) runs. Operator runs
         from a shell don't set it → default "manual" → always notify. -->
    <key>HOMELAB_RECONCILE_TRIGGER</key>
    <string>scheduled</string>
  </dict>

  <key>UserName</key>
  <string>homelab-admin</string>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>{{ reconcile_interval_seconds }}</integer>

  <key>StandardOutPath</key>
  <string>/var/log/homelab-ansible.log</string>
  <key>StandardErrorPath</key>
  <string>/var/log/homelab-ansible.err</string>
</dict>
</plist>
