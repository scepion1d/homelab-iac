<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Managed by Ansible. Do not hand-edit. -->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.homelab.mdns-reflector</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/lib/homelab/mdns-reflector/venv/bin/python3</string>
    <string>/usr/local/lib/homelab/mdns-reflector/mdns-reflector.py</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>MDNS_SRC_IP</key>
    <string>{{ mdns_vm_vmnet_ip }}</string>
    <key>MDNS_DST_IP</key>
    <string>{{ lan_ip }}</string>
    <key>MDNS_SERVICE_TYPES</key>
    <string>_hap._tcp.local.</string>
  </dict>

  <key>UserName</key>
  <string>root</string>

  <key>RunAtLoad</key>
  <false/>

  <key>KeepAlive</key>
  <true/>

  <key>ThrottleInterval</key>
  <integer>5</integer>

  <key>StandardOutPath</key>
  <string>/var/log/homelab-mdns-reflector.log</string>
  <key>StandardErrorPath</key>
  <string>/var/log/homelab-mdns-reflector.log</string>
</dict>
</plist>
