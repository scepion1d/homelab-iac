# Exported homelab CA certs (regenerated per cluster; no need to track)
homelab-ca.crt
homelab-ca-secret.yaml

# Bootstrap env file (holds passwords + tokens). See bootstrap/.env.example.
bootstrap/.env
.env

# Cert-manager root CA Secret snapshot (cert + private key). Written by
# bootstrap/dump-ca-secret.sh and consumed by bootstrap/restore-ca-secret.sh
# so a wipe+rebuild can keep previously-trusted devices working.
bootstrap/.ca-secret.yaml
bootstrap/.ca-secret.yaml.*

# Editor / OS noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.bak
*.bak.*

# Scratch files used by interactive commit-message workflows on Windows
# (pwsh + git struggles with multi-line `-m`; we use `-F .commit-msg.tmp`).
.commit-msg.tmp

# Python bytecode (ansible callback plugins compile to __pycache__ at runtime)
__pycache__/
*.pyc
